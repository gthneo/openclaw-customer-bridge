{
  "id": "openclaw-customer-bridge",
  "channels": [],
  "skills": ["./skills"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "dbPath": {
        "type": "string",
        "default": "~/.openclaw/customer_map.db"
      },
      "mergeThresholdAuto": {
        "type": "number",
        "default": 0.9,
        "minimum": 0,
        "maximum": 1
      },
      "mergeThresholdReview": {
        "type": "number",
        "default": 0.5,
        "minimum": 0,
        "maximum": 1
      },
      "vipExternalUserids": {
        "type": "array",
        "items": { "type": "string" },
        "default": []
      },
      "selfUserids": {
        "type": "array",
        "items": { "type": "string" },
        "default": [],
        "description": "Enterprise userids that count as 'you/your team' (group owner check). Empty array = treat all groups as self-owned."
      },
      "indexRefreshCron": {
        "type": "string",
        "default": "0 * * * *"
      },
      "wechatMcpServerName": {
        "type": "string",
        "default": "wechat",
        "description": "Name of the registered openclaw MCP server that proxies wechat-decrypt"
      },
      "wecomCorpId": {
        "type": "string",
        "description": "WeCom enterprise corpid; used for refresh_index / WeCom API calls"
      },
      "wecomAgentId": {
        "type": "string",
        "description": "Self-built application agentid"
      },
      "wecomSecret": {
        "type": "string",
        "secret": true,
        "description": "Self-built application secret"
      }
    }
  }
}
