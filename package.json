{
  "name": "@gthneo/openclaw-customer-bridge-plugin",
  "version": "0.3.5",
  "description": "OpenClaw plugin: cross-channel customer identity bridge (WeChat wxid ↔ WeCom external_userid ↔ unionid) + 12-class chat classifier + router skills",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "skills",
    "openclaw.plugin.json",
    "README.md"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "npm run build:types && npm run build:bundle",
    "build:bundle": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node20 --external:openclaw --external:better-sqlite3 --external:sharp --external:@modelcontextprotocol/sdk --external:@sinclair/typebox --external:eventsource --outfile=dist/index.js",
    "build:types": "tsc --emitDeclarationOnly --declaration --outDir dist",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "wecom",
    "wechat",
    "customer-bridge",
    "identity-resolution"
  ],
  "author": "gthneo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gthneo/openclaw-customer-bridge.git"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sinclair/typebox": "^0.34.49",
    "better-sqlite3": "^11.7.0",
    "eventsource": "^2.0.2",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0"
  }
}
